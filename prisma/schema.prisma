generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN

  @@map("user_role")
}

enum PurchaseType {
  INDIVIDUAL_MODEL
  BUNDLE

  @@map("purchase_type")
}

enum CreditPurchaseStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED

  @@map("credit_purchase_status")
}

enum PaymentMethod {
  BLIK
  CRYPTO
  PAYPAL
  REVOLUT

  @@map("payment_method")
}

enum CryptoCurrency {
  BTC
  ETH
  LTC
  USDC

  @@map("crypto_currency")
}

enum CreditTransactionType {
  PURCHASE
  SPEND
  REFUND
  ADJUSTMENT

  @@map("credit_transaction_type")
}

enum NotificationType {
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  PAYMENT_EXPIRED
  NEW_MODEL_AVAILABLE
  PURCHASE_COMPLETE

  @@map("notification_type")
}

enum ContentType {
  VIDEO
  PHOTO

  @@map("content_type")
}

enum AccessDuration {
  SEVEN_DAYS
  FOURTEEN_DAYS
  THIRTY_DAYS

  @@map("access_duration")
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String? // null for OAuth-only users
  name          String?
  discordId     String?   @unique @map("discord_id")
  role          Role      @default(USER)
  avatarUrl     String?   @map("avatar_url")
  creditBalance Int       @default(0) @map("credit_balance")
  isBanned      Boolean   @default(false) @map("is_banned")
  autoplay      Boolean   @default(false)
  emailVerified Boolean   @default(false) @map("email_verified")
  referralCode  String?   @unique @map("referral_code")
  customLinkId  String?   @map("custom_link_id")
  country       String?   @map("country") // User locale (from geo/IP); used by Go backend
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  creditPurchases      CreditPurchase[]    @relation("UserCreditPurchases")
  adminCreditPurchases CreditPurchase[]    @relation("AdminCreditPurchases")
  purchases            Purchase[]
  creditTransactions   CreditTransaction[]
  userAccess           UserAccess[]
  notifications        Notification[]
  sessions             Session[]
  accounts             Account[]
  favorites            Favorite[]
  referralsAsReferrer  Referral[]          @relation("Referrer")
  referralsAsReferee   Referral[]          @relation("Referee")
  referralLinkVisits   ReferralLinkVisit[]
  referralLinkVariants ReferralLinkVariant[]
  customLink           CustomLink?         @relation(fields: [customLinkId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([discordId])
  @@index([referralCode])
  @@index([customLinkId])
  @@map("users")
}

model Referral {
  id               String    @id @default(cuid())
  referrerId       String    @map("referrer_id")
  refereeId        String    @map("referee_id")
  creditsAwardedAt DateTime? @map("credits_awarded_at")
  creditsAmount    Int?      @map("credits_amount")
  createdAt        DateTime  @default(now()) @map("created_at")

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)

  @@unique([refereeId])
  @@index([referrerId])
  @@index([refereeId])
  @@map("referrals")
}

model ReferralLinkVisit {
  id         String   @id @default(cuid())
  referrerId String   @map("referrer_id")
  ipAddress  String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  referer    String?
  variantKey String   @default("default") @map("variant_key")
  createdAt  DateTime @default(now()) @map("created_at")

  referrer User @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([referrerId, createdAt])
  @@index([referrerId, variantKey])
  @@index([createdAt])
  @@map("referral_link_visits")
}

model ReferralLinkVariant {
  id         String   @id @default(cuid())
  referrerId String   @map("referrer_id")
  variantKey String   @map("variant_key")
  name       String?
  createdAt  DateTime @default(now()) @map("created_at")

  referrer User @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@unique([referrerId, variantKey])
  @@index([referrerId])
  @@map("referral_link_variants")
}

// ─── NextAuth required tables ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  sessionToken String   @unique @map("session_token")
  expires      DateTime
  deviceInfo   Json?    @map("device_info")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Content Models ─────────────────────────────────────────────────────────

model Country {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // ISO 3166-1 alpha-2
  flagEmoji String?  @map("flag_emoji")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  models Model[]

  @@index([code])
  @@map("countries")
}

model Model {
  id           String    @id @default(cuid())
  name         String // Display name (what users see)
  folderName   String    @unique @map("folder_name") // R2 folder name
  description  String?
  avatarPath   String?   @map("avatar_path") // R2 relative path to avatar (under files/avatars/)
  countryId    String?   @map("country_id")
  isActive     Boolean   @default(true) @map("is_active")
  isFeatured   Boolean   @default(false) @map("is_featured")
  lastSyncedAt DateTime? @map("last_synced_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  country      Country?      @relation(fields: [countryId], references: [id])
  contentItems ContentItem[]
  purchases    Purchase[]
  userAccess   UserAccess[]

  @@index([folderName])
  @@index([countryId])
  @@index([isActive])
  @@map("models")
}

model ContentItem {
  id              String      @id @default(cuid())
  modelId         String      @map("model_id")
  uniqueId        String      @unique @map("unique_id") // e.g. "0h9pjtspoj4o2e4ny06bf"
  contentType     ContentType @map("content_type")
  thumbnailPath   String?     @map("thumbnail_path") // R2 relative path
  sourceVideoPath String?     @map("source_video_path") // R2 relative path
  hlsMasterPath   String?     @map("hls_master_path") // R2 relative path
  hlsFolderPath   String?     @map("hls_folder_path") // R2 relative path
  duration        Int? // Video duration in seconds (null for photos)
  isActive        Boolean     @default(true) @map("is_active")
  isHidden        Boolean     @default(false) @map("is_hidden")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  model     Model      @relation(fields: [modelId], references: [id], onDelete: Cascade)
  favorites Favorite[]

  @@index([modelId])
  @@index([uniqueId])
  @@index([contentType])
  @@index([isActive])
  @@map("content_items")
}

// ─── Promo Codes ────────────────────────────────────────────────────────────

enum PromoDiscountType {
  PERCENT
  FIXED_CREDITS

  @@map("promo_discount_type")
}

model PromoCode {
  id                 String            @id @default(cuid())
  code               String            @unique
  discountType       PromoDiscountType @map("discount_type")
  discountValue      Int               @map("discount_value") // percent (1-100) or fixed credits
  minPurchaseCredits Int               @default(0) @map("min_purchase_credits")
  maxUses            Int?              @map("max_uses") // null = unlimited
  usedCount          Int               @default(0) @map("used_count")
  expiresAt          DateTime?         @map("expires_at") // null = never
  isActive           Boolean           @default(true) @map("is_active")
  oncePerUser        Boolean           @default(false) @map("once_per_user")
  firstPurchaseOnly  Boolean           @default(false) @map("first_purchase_only")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  creditPurchases CreditPurchase[]

  @@index([code])
  @@index([isActive])
  @@map("promo_codes")
}

// ─── Credit System ──────────────────────────────────────────────────────────

model CreditPackage {
  id        String   @id @default(cuid())
  name      String // e.g. "Starter Pack"
  credits   Int // number of credits
  price     Float // price in USD (or base currency)
  tier      Int      @default(0) // for sorting (lower = first)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creditPurchases CreditPurchase[]

  @@index([tier])
  @@index([isActive])
  @@map("credit_packages")
}

model CreditPurchase {
  id              String               @id @default(cuid())
  userId          String               @map("user_id")
  creditPackageId String               @map("credit_package_id")
  credits         Int
  amount          Float
  paymentMethod   PaymentMethod        @map("payment_method")
  transactionCode String               @unique @map("transaction_code") // unique code for this purchase
  // BLIK
  blikCode        String?              @map("blik_code") // e.g. "462-041"
  // Crypto
  cryptoCurrency  CryptoCurrency?      @map("crypto_currency")
  txId            String?              @map("tx_id") // user-provided transaction ID
  // General
  expirationTime  DateTime             @map("expiration_time")
  status          CreditPurchaseStatus @default(PENDING)
  paymentProofUrl String?              @map("payment_proof_url")
  adminNotes      String?              @map("admin_notes") @db.Text
  adminVerifiedAt DateTime?            @map("admin_verified_at")
  adminId         String?              @map("admin_id")
  retryCount      Int                  @default(0) @map("retry_count")
  promoCodeId     String?              @map("promo_code_id")
  customLinkId    String?              @map("custom_link_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  // Relations
  user              User               @relation("UserCreditPurchases", fields: [userId], references: [id], onDelete: Cascade)
  admin             User?              @relation("AdminCreditPurchases", fields: [adminId], references: [id], onDelete: SetNull)
  creditPackage     CreditPackage      @relation(fields: [creditPackageId], references: [id], onDelete: Restrict)
  promoCode         PromoCode?         @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  customLink        CustomLink?        @relation(fields: [customLinkId], references: [id], onDelete: SetNull)
  creditTransaction CreditTransaction?

  @@index([userId])
  @@index([userId, status])
  @@index([creditPackageId])
  @@index([transactionCode])
  @@index([status])
  @@index([expirationTime])
  @@index([customLinkId])
  @@map("credit_purchases")
}

// ─── Purchases (spending credits on models/bundle) ──────────────────────────

model Purchase {
  id             String          @id @default(cuid())
  userId         String          @map("user_id")
  modelId        String?         @map("model_id") // null = bundle purchase
  purchaseType   PurchaseType    @map("purchase_type")
  accessDuration AccessDuration? @map("access_duration") // null for bundle (lifetime)
  creditsSpent   Int             @map("credits_spent")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  model             Model?             @relation(fields: [modelId], references: [id], onDelete: SetNull)
  userAccess        UserAccess[]
  creditTransaction CreditTransaction?

  @@index([userId])
  @@index([userId, createdAt])
  @@index([modelId])
  @@index([createdAt])
  @@map("purchases")
}

model CreditTransaction {
  id               String                @id @default(cuid())
  userId           String                @map("user_id")
  type             CreditTransactionType
  amount           Int // positive = add, negative = deduct
  creditPurchaseId String?               @unique @map("credit_purchase_id")
  purchaseId       String?               @unique @map("purchase_id")
  description      String
  createdAt        DateTime              @default(now()) @map("created_at")

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditPurchase CreditPurchase? @relation(fields: [creditPurchaseId], references: [id], onDelete: SetNull)
  purchase       Purchase?       @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("credit_transactions")
}

// ─── Access Control ─────────────────────────────────────────────────────────

model UserAccess {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  modelId    String?   @map("model_id") // null = bundle (all models)
  purchaseId String?   @map("purchase_id") // null = admin-granted access
  expiresAt  DateTime? @map("expires_at") // null = lifetime
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  model    Model?    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  purchase Purchase? @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@unique([userId, modelId, purchaseId])
  @@index([userId])
  @@index([userId, expiresAt])
  @@index([modelId])
  @@index([purchaseId])
  @@index([expiresAt])
  @@map("user_access")
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model Favorite {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  contentItemId String   @map("content_item_id")
  createdAt     DateTime @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@unique([userId, contentItemId])
  @@index([userId])
  @@index([contentItemId])
  @@map("favorites")
}

// ─── Settings (key-value store) ─────────────────────────────────────────────

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("settings")
}

// ─── Custom Links Analytics ─────────────────────────────────────────────────

model CustomLink {
  id          String   @id @default(cuid())
  slug        String   @unique
  destination String // URL to redirect to
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  visits          LinkVisit[]
  users           User[]
  creditPurchases CreditPurchase[]

  @@index([slug])
  @@index([isActive])
  @@map("custom_links")
}

model LinkVisit {
  id           String   @id @default(cuid())
  customLinkId String   @map("custom_link_id")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  referer      String?
  createdAt    DateTime @default(now()) @map("created_at")

  customLink CustomLink @relation(fields: [customLinkId], references: [id], onDelete: Cascade)

  @@index([customLinkId])
  @@index([customLinkId, createdAt])
  @@index([createdAt])
  @@map("link_visits")
}
