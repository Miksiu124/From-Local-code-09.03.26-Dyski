generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum PurchaseType {
  INDIVIDUAL_MODEL
  BUNDLE
}

enum CreditPurchaseStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum PaymentMethod {
  BLIK
  CRYPTO
  PAYPAL
  REVOLUT
}

enum CryptoCurrency {
  BTC
  ETH
  USDT
  USDC
}

enum CreditTransactionType {
  PURCHASE
  SPEND
  REFUND
}

enum NotificationType {
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  PAYMENT_EXPIRED
  NEW_MODEL_AVAILABLE
  PURCHASE_COMPLETE
}

enum ContentType {
  VIDEO
  PHOTO
}

enum AccessDuration {
  SEVEN_DAYS
  THIRTY_DAYS
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String?  // null for OAuth-only users
  name            String?
  discordId       String?  @unique
  role            Role     @default(USER)
  avatarUrl       String?
  creditBalance   Int      @default(0)
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  creditPurchases     CreditPurchase[]    @relation("UserCreditPurchases")
  adminCreditPurchases CreditPurchase[]   @relation("AdminCreditPurchases")
  purchases           Purchase[]
  creditTransactions  CreditTransaction[]
  userAccess          UserAccess[]
  notifications       Notification[]
  sessions            Session[]
  accounts            Account[]
  favorites           Favorite[]

  @@index([email])
  @@index([discordId])
}

// ─── NextAuth required tables ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime
  deviceInfo   Json?
  ipAddress    String?
  userAgent    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Content Models ─────────────────────────────────────────────────────────

model Country {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // ISO 3166-1 alpha-2
  flagEmoji String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models Model[]

  @@index([code])
}

model Model {
  id             String    @id @default(cuid())
  name           String    // Display name (what users see)
  folderName     String    @unique // R2 folder name
  description    String?
  avatarPath     String?   // R2 relative path to avatar (under files/avatars/)
  countryId      String?
  isActive       Boolean   @default(true)
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  country       Country?      @relation(fields: [countryId], references: [id])
  contentItems  ContentItem[]
  purchases     Purchase[]
  userAccess    UserAccess[]

  @@index([folderName])
  @@index([countryId])
  @@index([isActive])
}

model ContentItem {
  id              String      @id @default(cuid())
  modelId         String
  uniqueId        String      @unique // e.g. "0h9pjtspoj4o2e4ny06bf"
  contentType     ContentType
  thumbnailPath   String?     // R2 relative path
  sourceVideoPath String?     // R2 relative path
  hlsMasterPath   String?     // R2 relative path
  hlsFolderPath   String?     // R2 relative path
  duration        Int?        // Video duration in seconds (null for photos)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  model     Model      @relation(fields: [modelId], references: [id], onDelete: Cascade)
  favorites Favorite[]

  @@index([modelId])
  @@index([uniqueId])
  @@index([contentType])
  @@index([isActive])
}

// ─── Credit System ──────────────────────────────────────────────────────────

model CreditPackage {
  id        String   @id @default(cuid())
  name      String   // e.g. "Starter Pack"
  credits   Int      // number of credits
  price     Float    // price in USD (or base currency)
  tier      Int      @default(0) // for sorting (lower = first)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creditPurchases CreditPurchase[]

  @@index([tier])
  @@index([isActive])
}

model CreditPurchase {
  id              String               @id @default(cuid())
  userId          String
  creditPackageId String
  credits         Int
  amount          Float
  paymentMethod   PaymentMethod
  transactionCode String               @unique // unique code for this purchase
  // BLIK
  blikCode        String?              // e.g. "462-041"
  // Crypto
  cryptoCurrency  CryptoCurrency?
  txId            String?              // user-provided transaction ID
  // General
  expirationTime  DateTime
  status          CreditPurchaseStatus @default(PENDING)
  paymentProofUrl String?
  adminNotes      String?              @db.Text
  adminVerifiedAt DateTime?
  adminId         String?
  retryCount      Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  user            User          @relation("UserCreditPurchases", fields: [userId], references: [id], onDelete: Cascade)
  admin           User?         @relation("AdminCreditPurchases", fields: [adminId], references: [id], onDelete: SetNull)
  creditPackage   CreditPackage @relation(fields: [creditPackageId], references: [id], onDelete: Restrict)
  creditTransaction CreditTransaction?

  @@index([userId])
  @@index([userId, status])
  @@index([creditPackageId])
  @@index([transactionCode])
  @@index([status])
  @@index([expirationTime])
}

// ─── Purchases (spending credits on models/bundle) ──────────────────────────

model Purchase {
  id             String          @id @default(cuid())
  userId         String
  modelId        String?         // null = bundle purchase
  purchaseType   PurchaseType
  accessDuration AccessDuration? // null for bundle (lifetime)
  creditsSpent   Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  model             Model?             @relation(fields: [modelId], references: [id], onDelete: SetNull)
  userAccess        UserAccess[]
  creditTransaction CreditTransaction?

  @@index([userId])
  @@index([userId, createdAt])
  @@index([modelId])
  @@index([createdAt])
}

model CreditTransaction {
  id               String                @id @default(cuid())
  userId           String
  type             CreditTransactionType
  amount           Int                   // positive = add, negative = deduct
  creditPurchaseId String?               @unique
  purchaseId       String?               @unique
  description      String
  createdAt        DateTime              @default(now())

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditPurchase CreditPurchase? @relation(fields: [creditPurchaseId], references: [id], onDelete: SetNull)
  purchase       Purchase?       @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ─── Access Control ─────────────────────────────────────────────────────────

model UserAccess {
  id         String    @id @default(cuid())
  userId     String
  modelId    String?   // null = bundle (all models)
  purchaseId String
  expiresAt  DateTime? // null = lifetime
  createdAt  DateTime  @default(now())

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  model    Model?   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@unique([userId, modelId, purchaseId])
  @@index([userId])
  @@index([userId, expiresAt])
  @@index([modelId])
  @@index([purchaseId])
  @@index([expiresAt])
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model Favorite {
  id            String      @id @default(cuid())
  userId        String
  contentItemId String
  createdAt     DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@unique([userId, contentItemId])
  @@index([userId])
  @@index([contentItemId])
}

// ─── Settings (key-value store) ─────────────────────────────────────────────

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}
