# Produkcja: sekcja Grafana jest już w nginx.conf.production (grafana.dyskiof.net).
# Lokalny dev: możesz wkleić poniższe bloki do nginx.conf albo użyć include.
#
# Przed: cert (SAN) + DNS — domena w przykładzie: grafana.dyskiof.net.

# --- HTTP -> HTTPS
server {
    listen 80;
    server_name grafana.dyskiof.net;
    location / {
        return 301 https://$host$request_uri;
    }
}

# --- HTTPS -> Grafana w kontenerze otel-lgtm:3000
server {
    listen 443 ssl;
    http2 on;
    server_name grafana.dyskiof.net;

    resolver 127.0.0.11 valid=10s ipv6=off;
    set $otel_up "otel-lgtm";

    ssl_certificate     /etc/nginx/certs/fullchain.pem;
    ssl_certificate_key /etc/nginx/certs/privkey.pem;

    location / {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Grafana live / websockets
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_pass http://$otel_up:3000;
    }
}
