# ═══════════════════════════════════════════════════════════════
# Content Platform — PRODUCTION Environment
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in all values before deploying.
# Generate secrets with: openssl rand -hex 32
#
# NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
ENVIRONMENT=production
PORT=8080
FRONTEND_URL=https://yourdomain.com
API_URL=http://api:8080/api

# ── Database ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32 | tr -d '=/+' | head -c 40
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
# Docker internal: sslmode=disable OK. External Postgres: use sslmode=require (see SECURITY_AUDIT.md)
DATABASE_URL=postgresql://platform:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/content_platform?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT & Sessions ───────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_SECRET
# Session TTL (pick one): SESSION_TTL_DAYS=7 (shorter, audit), or SESSION_TOKEN_TTL=2592000 (30 days)
# SESSION_TTL_DAYS=7
# Optional: DISABLE_BEARER_AUTH=true — cookie-only auth (no Bearer header, reduces token leakage)
# DISABLE_BEARER_AUTH=false

# ── NextAuth ─────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
AUTH_URL=https://yourdomain.com

# ── Cloudflare R2 ────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=files
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# ── HLS Streaming Security ──────────────────────────────────
# Generate: openssl rand -hex 32
STREAMING_TOKEN_SECRET=CHANGE_ME_STREAMING_SECRET
STREAMING_TOKEN_TTL=21600

# ── Discord OAuth (optional) ─────────────────────────────────
# Create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://yourdomain.com/api/auth/discord/callback

# ── Admin ────────────────────────────────────────────────────
# Comma-separated list of admin emails
ADMIN_EMAILS=your-admin@proton.me

# ── BLIK ─────────────────────────────────────────────────────
BLIK_EXPIRATION_MINUTES=2

# ── SMTP (Self-hosted Postfix relay) ─────────────────────────
# Uses boky/postfix container as a local mail relay — no external provider needed.
# https://github.com/bokysan/docker-postfix
SMTP_HOST=smtp
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# Mail relay hostname (must match your MX/SPF/DKIM DNS records)
SMTP_HOSTNAME=mail.yourdomain.com
SMTP_ALLOWED_DOMAINS=yourdomain.com

# ── Nginx ────────────────────────────────────────────────────
# For production, point to the production nginx config:
NGINX_CONFIG=./nginx/nginx.conf.production

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
