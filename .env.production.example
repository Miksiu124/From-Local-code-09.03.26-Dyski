# ═══════════════════════════════════════════════════════════════
# Content Platform — PRODUCTION Environment
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in all values before deploying.
# Generate secrets with: openssl rand -hex 32
#
# NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
ENVIRONMENT=production
PORT=8080
FRONTEND_URL=https://yourdomain.com
# Optional: extra browser origins allowed to call the API (comma-separated). Use when HTML is served from a CDN host
# (e.g. https://cdn.yourdomain.com) while FRONTEND_URL is the main site — required for cookies on cross-origin /api.
# CORS_EXTRA_ORIGINS=https://cdn.yourdomain.com
API_URL=http://api:8080/api

# ── Database ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32 | tr -d '=/+' | head -c 40
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
# Docker internal: sslmode=disable OK. External Postgres: use sslmode=require (see SECURITY_AUDIT.md)
DATABASE_URL=postgresql://platform:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/content_platform?sslmode=disable
# Na VPS (Dyskiof): wymuś pliki compose, żeby `docker compose up` nigdy nie wstało na domyślnym `postgres_data` (pusty), tylko na wolumenie klastra:
# COMPOSE_FILE=docker-compose.yml:docker-compose.vps.yml:docker-compose.use3566349.yml:docker-compose.lgtm.yml
# (bez `docker-compose.lgtm.yml` zostaw tylko trzy pliki, jeśli nie używasz observability)
# /admin/observability — status pliku kopii: zamontuj postgres_backups na API (docker-compose.vps.yml) i ustaw:
POSTGRES_BACKUP_DIR=/backups
POSTGRES_BACKUP_DB_NAME=content_platform

# OpenTelemetry: logi (slog→Loki) + ślady HTTP (→Tempo) + metryki RED/runtime (→Prometheus) — jeden endpoint OTLP; z -f docker-compose.lgtm.yml
# (wartości są też w docker-compose.lgtm.yml pod service api; poniższe tylko gdy nadpisujesz per środowisko)
# Uwaga: nie ustawiaj OSOBNO OTEL_EXPORTER_OTLP_TRACES/LOGS/METRICS_ENDPOINT na host:port bez
# /v1/... — Go SDK użyje wtedy path „/” (404 w kolektorze). Wspólna baza: tylko poniższe, albo pełne URL z ścieżką.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-lgtm:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=content-api
# Udział trace w prod (0–1, domyślnie 0.25): # OTEL_TRACES_SAMPLE_RATIO=0.25
#
# Zamiast self-host LGTM — Grafana Cloud (skopiuj 1:1 z portalu: OpenTelemetry → Configure):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-….grafana.net/otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20…   # token z panelu; bez wklejania tutaj prawdziwego sekretu w repo
# OTEL_SERVICE_NAME=content-api

# ── PostgreSQL backups (docker-compose.vps.yml → content-postgres-backup) ──
# POSTGRES_PASSWORD jest współdzielony z serwerem postgres — nie duplikuj.
# TZ=Europe/Warsaw — kiedy o północy liczy się „dzień” dla @daily (go-cron).
# POSTGRES_BACKUP_SCHEDULE=@daily   # lub np. 0 3 * * * (03:00 co dzień)
# BACKUP_KEEP_DAYS=7
# BACKUP_KEEP_WEEKS=4
# BACKUP_KEEP_MONTHS=6

# ── PostgreSQL → R2 (docker-compose.vps.yml → content-postgres-backup-r2) ──
# Wymaga: docker compose build (obraz z AWS CLI). Token R2 musi mieć zapis do wybranego bucketu.
# NIE powielaj w pliku dwóch linii R2_ACCESS_KEY_ID — parser bierze OSTATNIĄ wartość dla całego stacku (API też).
#    Błąd S3 „Credential access key has length 64” = do Access Key wklejono Secret albo zła linia wygrała.
# Osobny token tylko pod backup (API używa R2_* powyżej; backup-r2: fallback z R2_BACKUP_*):
# R2_BACKUP_ACCESS_KEY_ID=
# R2_BACKUP_SECRET_ACCESS_KEY=
# R2_BACKUP_ENDPOINT=   # puste = to samo co R2_ENDPOINT (inny account R2 = ustaw pełny URL .r2.cloudflarestorage.com)
# R2_DB_BACKUP_SYNC_ENABLED=0   # ustaw 1 aby włączyć upload kopii do R2
# R2_DB_BACKUP_BUCKET_NAME=db-backups-only   # opcjonalnie: osobny bucket tylko pod backupy (puste = ten sam co R2_BUCKET_NAME)
# R2_DB_BACKUP_PREFIX=db-backups   # prefiks obiektów w bucketcie (gdy jeden bucket z mediami — osobny „folder”)
# R2_DB_BACKUP_SYNC_CRON=45 3 * * *   # po zwykłym backupie (@daily); strefa: TZ
# R2_BACKUP_SYNC_DELETE=1   # 1 = usuń z R2 pliki usunięte lokalnie (rotacja); 0 = tylko dopisywanie
# R2_SYNC_ON_START=0   # 1 = jednorazowy sync przy starcie kontenera (np. pierwszy deploy)

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT & Sessions ───────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_SECRET
# Default session TTL is 7 days. For longer: SESSION_TOKEN_TTL=2592000 (30 days)
# SESSION_TTL_DAYS=7
# Optional: DISABLE_BEARER_AUTH=true — cookie-only auth (no Bearer header, reduces token leakage)
# DISABLE_BEARER_AUTH=false

# ── NextAuth ─────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
AUTH_URL=https://yourdomain.com

# ── Cloudflare R2 ────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=files
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://files.yourdomain.com  # Public hostname of workers/avatars-cdn (NOT r2.cloudflarestorage.com)

# ── HLS + Cloudflare Worker (files CDN) ─────────────────────
# Segmenty .ts/.m4s idą na R2_PUBLIC_URL z ?token=&expires= (HMAC jak w Workerze).
# W wrangler.toml / sekretach Workera:
#   MEDIA_CDN_SIGNING_SECRET = ta sama wartość co poniżej (albo zostaw puste i używany jest STREAMING_TOKEN_SECRET)
#   MEDIA_CDN_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com  (puste = Access-Control-Allow-Origin: *)
# Backend:
#   MEDIA_CDN_SIGNING_SECRET=...   # opcjonalnie; domyślnie = STREAMING_TOKEN_SECRET
#   MEDIA_CDN_SIGN_URLS musi być włączone (domyślnie tak). MEDIA_CDN_SIGN_URLS=0 = niepodpisane URL-e → Worker zwraca 403.
# Awaryjnie (omija Worker, segmenty przez API Go): HLS_USE_API_SEGMENTS=true

# ── Payment Proof Bucket (R2) ────────────────────────────────
# Optional. If empty, proofs go to main bucket (proofs/ prefix).
# Use a separate bucket for payment proofs if desired.
# R2_PROOF_ACCESS_KEY_ID=
# R2_PROOF_SECRET_ACCESS_KEY=
# R2_PROOF_BUCKET_NAME=
# R2_PROOF_ENDPOINT=

# ── HLS Streaming Security ──────────────────────────────────
# Generate: openssl rand -hex 32
STREAMING_TOKEN_SECRET=CHANGE_ME_STREAMING_SECRET
STREAMING_TOKEN_TTL=21600
# HLS_USE_PUBLIC_CDN_SEGMENTS=  # empty = on when R2_PUBLIC_URL set; 0 = presigned segment URLs

# Media CDN signing (Cloudflare Worker gatekeeper) — same value as wrangler secret MEDIA_CDN_SIGNING_SECRET
# MEDIA_CDN_SIGNING_SECRET=  # optional; defaults to STREAMING_TOKEN_SECRET
# MEDIA_CDN_URL_TTL_SEC=1800
# MEDIA_CDN_SIGN_URLS=0  # unsigned CDN URLs (emergency only)

# ── Discord OAuth (optional) ─────────────────────────────────
# Create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://yourdomain.com/api/auth/discord/callback
# Bot token + guild ID used to verify server membership for social rewards.
DISCORD_BOT_TOKEN=
DISCORD_REWARD_GUILD_ID=

# ── Admin ────────────────────────────────────────────────────
# Comma-separated list of admin emails
ADMIN_EMAILS=your-admin@proton.me

# ── BLIK ─────────────────────────────────────────────────────
BLIK_EXPIRATION_MINUTES=2

# ── Outbound email ────────────────────────────────────────────
# Resend: API key + verified domain; SMTP_FROM must be an allowed sender in Resend.
RESEND_API_KEY=
SMTP_FROM=noreply@yourdomain.com
# Opcjonalnie: oddzielny nadawca dla kampanii marketingowych (wbudowane szablony). Puste = SMTP_FROM.
# MARKETING_EMAIL_FROM=newsletter@yourdomain.com
# Opcjonalnie: nadawca wiadomości transakcyjnych (weryfikacja, reset, potwierdzenie płatności). Puste = SMTP_FROM.
# TRANSACTIONAL_EMAIL_FROM=noreply@tx.yourdomain.com

# Opcjonalnie: zamiast Resend — zewnętrzny SMTP (np. Mailpit w labie). Zwykle puste na VPS; wtedy RESEND_API_KEY puste.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Abandoned credit checkout reminder (cron co 15 min; wymaga skonfigurowanej wysyłki e-mail)
# CHECKOUT_REMINDER_DELAY_MINUTES=45
# CHECKOUT_REMINDER_LOOKBACK_DAYS=14
# CHECKOUT_REMINDER_DISABLED=1

# ── Kampanie marketingowe (wbudowane szablony HTML w API + growth_events + /api/growth-hacker) ──
# Jeden harmonogram cron dla kampanii „batch” (winback, social proof, repeat buyer). Legacy: WINBACK_CRON jeśli MARKETING_CRON puste.
# Domyślnie (gdy oba puste): @every 24h — pierwsze uruchomienie ~24h po starcie API; ręcznie: POST /api/admin/marketing/run-cron (sesja admin).
# MARKETING_CRON=@every 24h
# MARKETING_CRON=0 9 * * *
# Opcjonalnie: Bearer do POST /api/ops/marketing/run-cron (bez sesji admina; trzymaj w sekrecie).
# MARKETING_OPS_KEY=
#
# Przy limicie 50k/mies. zacznij od kampanii o najwyższej intencji:
# 1) repeat buyer, 2) social proof, 3) favorite nudge, 4) winback. Zwiększaj batch dopiero po sprawdzeniu wypisów i odbić.
#
# Winback — długa nieaktywność (ostatni growth_events vs last_login_at). WYŁ domyślnie.
# WINBACK_EMAIL_ENABLED=1
# WINBACK_INACTIVITY_DAYS=45
# WINBACK_COOLDOWN_DAYS=90
# WINBACK_BATCH_LIMIT=100
# WINBACK_TEMPLATE_SLUG=winback-soft
# WINBACK_HOOK_LINE=…
# WINBACK_CTA_PATH=/models
# WINBACK_SITE_NAME=Dyskiof
# WINBACK_FIRSTNAME_FALLBACK=Tam
# WINBACK_TEMPLATE_DEFAULTS_JSON={"stat1":"…"}
#
# Social proof — kiedyś oglądali treść (first_play / content_detail_view / video_engagement), teraz cisza.
# SOCIAL_PROOF_EMAIL_ENABLED=1
# SOCIAL_PROOF_TEMPLATE_SLUG=social-proof-drop
# SOCIAL_PROOF_INACTIVITY_DAYS=14
# SOCIAL_PROOF_COOLDOWN_DAYS=45
# SOCIAL_PROOF_ENGAGEMENT_LOOKBACK_DAYS=90
# SOCIAL_PROOF_BATCH_LIMIT=150
# SOCIAL_PROOF_TRENDING_TITLE=…
# SOCIAL_PROOF_PROOF_LINE=…
# SOCIAL_PROOF_CTA_PATH=/models
# SOCIAL_PROOF_TEMPLATE_DEFAULTS_JSON={}
#
# Po zdarzeniu lejka: pierwsze „dodaj do ulubionych” (favorite_toggled, favorited=true) — jednorazowo na użytkownika.
# FAVORITE_NUDGE_EMAIL_ENABLED=1
# FAVORITE_NUDGE_TEMPLATE_SLUG=favorite-nudge
# FAVORITE_NUDGE_HOOK_LINE=…
# FAVORITE_NUDGE_CTA_PATH=/favorites
# FAVORITE_NUDGE_TRENDING_TITLE=…   # jeśli szablon wymaga
# FAVORITE_NUDGE_PROOF_LINE=…
# FAVORITE_NUDGE_TEMPLATE_DEFAULTS_JSON={}
#
# Jednorazowa kampania „kiedykolwiek kupili” — kod + linki /l/vip10-{a,b,c} (A/B/C klików). Migracja: promo DYSKIOF10BK + linki.
# REPEAT_BUYER_PROMO_EMAIL_ENABLED=1
# REPEAT_BUYER_PROMO_CODE=DYSKIOF10BK
# REPEAT_BUYER_TEMPLATE_SLUG=repeat-buyer-10
# REPEAT_BUYER_AB_LINK_SLUGS=vip10-a,vip10-b,vip10-c
# REPEAT_BUYER_BATCH_LIMIT=500
# Jedna wiadomość na użytkownika (A/B/C = jeden wariant z hasha user id). Cron w jednym przebiegu wysyła wiele partii LIMIT aż kolejka się skończy (nie trzeba czekać kolejnych dni).
# REPEAT_BUYER_TEMPLATE_DEFAULTS_JSON={}
#
# Welcome (async po weryfikacji e-mail / nowy Discord) — szablon marketingowy, wymaga zgody marketingowej.
# WELCOME_EMAIL_ENABLED=1
# WELCOME_TEMPLATE_SLUG=welcome-value-stack
# WELCOME_HOOK_LINE=…
# WELCOME_BENEFIT_LINE=…
# WELCOME_CTA_PATH=/models
# WELCOME_TEMPLATE_DEFAULTS_JSON={}
#
# Starter offer (cron) — zweryfikowani, jeszcze bez zakupu, okno dni od pierwszego email_verified.
# STARTER_OFFER_EMAIL_ENABLED=1
# STARTER_OFFER_DAYS_MIN=3
# STARTER_OFFER_DAYS_MAX=14
# STARTER_OFFER_COOLDOWN_DAYS=60
# STARTER_OFFER_BATCH_LIMIT=40
# STARTER_OFFER_TEMPLATE_SLUG=starter-offer-welcome
# STARTER_OFFER_CTA_PATH=/purchase
#
# At-risk + lapsed (cron) — kupujący, pasma nieaktywności; patrz docs/MARKETING_CAMPAIGNS.md
# AT_RISK_EMAIL_ENABLED=1
# LAPSED_BUYER_EMAIL_ENABLED=1
#
# Wymaga: RESEND_API_KEY + SMTP_FROM lub SMTP_HOST, Redis, migracje marketing_* + users.marketing_email_opt_in.
# Wypis: GET /api/public/marketing-unsubscribe?t=…

# ── Nginx ────────────────────────────────────────────────────
# For production, point to the production nginx config:
NGINX_CONFIG=./nginx/nginx.conf.production

# ── Frontend ─────────────────────────────────────────────────
# Required for canonical URLs, og:url, JSON-LD, and HLS: must be the origin where Next.js proxies /api (not a static CDN host).
# Rebuild frontend after changing.
NEXT_PUBLIC_APP_URL=https://yourdomain.com
# Optional: Discord invite (https://discord.gg/...) — header icon; rebuild frontend after changing.
# NEXT_PUBLIC_DISCORD_SERVER_URL=
# Hostname(s) R2 public CDN for next/image + HLS credentials (comma-separated). Match Worker custom domain.
# NEXT_PUBLIC_MEDIA_HOST=files.yourdomain.com
