# Kopiuj na serwer: $VPS_PATH/.env.vps  (obok .env — plik tylko na VPS, nie commituj).
# Deploy (deploy-vps.ps1) czyta tę linię, gdy w lokalnym .env.deploy brakuje VPS_USE_POSTGRES_CLUSTER
# (np. git pull / CI / nowy klon) — dzięki temu `docker compose` zawsze dorzuca
# -f docker-compose.use3566349.yml i montuje wolumen contentvault_postgres_cluster (baza z przychodami).
#
VPS_USE_POSTGRES_CLUSTER=1
