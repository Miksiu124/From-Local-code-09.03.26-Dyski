# Kopiuj na serwer: $VPS_PATH/.env.vps  (obok .env — plik tylko na VPS, nie commituj).
# Używają: deploy-vps.ps1 (czytając zdalnie), vps-rebuild.sh, vps-up-prod (logika w scripts/compose-vps-files.sh).
# VPS_USE_POSTGRES_CLUSTER=1 — docker-compose.use3566349.yml → contentvault_postgres_cluster
# Opcjonalnie: VPS_USE_LGTM=1 — zawsze -f docker-compose.lgtm.yml (poza tym: istnienie .env.lgtm)
#
VPS_USE_POSTGRES_CLUSTER=1
# VPS_USE_LGTM=0
