# ═══════════════════════════════════════════════════════════════
# Dyskiof.net — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Generate secrets: openssl rand -hex 32
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql://platform:change_me_to_a_strong_password@postgres:5432/content_platform?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT & Sessions ───────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRY_SECS=2592000

# ── Cloudflare R2 ────────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_key
R2_SECRET_ACCESS_KEY=your_secret
R2_BUCKET_NAME=your_bucket
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# ── HLS Streaming ─────────────────────────────────────────────
STREAMING_TOKEN_SECRET=CHANGE_ME_ANOTHER_RANDOM_64_CHAR_STRING
STREAMING_TOKEN_TTL=21600

# ── Admin (comma-separated emails) ───────────────────────────
ADMIN_EMAILS=your_email@example.com

# ── BLIK ─────────────────────────────────────────────────────
BLIK_EXPIRATION_MINUTES=2

# ── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp
SMTP_PORT=587
SMTP_FROM=noreply@yourdomain.com
SMTP_HOSTNAME=mail.yourdomain.com
SMTP_ALLOWED_DOMAINS=yourdomain.com

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost
# Optional: invite link (https://discord.gg/...) — ikona w nagłówku, gdy ustawione
NEXT_PUBLIC_DISCORD_SERVER_URL=

# ── Turnstile (Cloudflare) ───────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── OpenTelemetry (Loki + Tempo + metryki) — opcjonalnie ─────
# Bez poniższego endpointu API zostaje na NoopTracerProvider — w Grafanie Tempo będzie puste.
# Z docker-compose.lgtm.yml zmienne OTLP są dokładane do serwisu api; lokalnie bez LGTM ustaw np.:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=content-api
# OTEL_TRACES_SAMPLE_RATIO=1
