# ═══════════════════════════════════════════════════════════════
# Dyskiof.net — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Generate secrets: openssl rand -hex 32
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql://platform:change_me_to_a_strong_password@postgres:5432/content_platform?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT & Sessions ───────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRY_SECS=2592000

# ── Cloudflare R2 ────────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_key
R2_SECRET_ACCESS_KEY=your_secret
R2_BUCKET_NAME=your_bucket
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# ── HLS Streaming ─────────────────────────────────────────────
STREAMING_TOKEN_SECRET=CHANGE_ME_ANOTHER_RANDOM_64_CHAR_STRING
STREAMING_TOKEN_TTL=21600

# ── Admin (comma-separated emails) ───────────────────────────
ADMIN_EMAILS=your_email@example.com

# ── BLIK ─────────────────────────────────────────────────────
BLIK_EXPIRATION_MINUTES=2

# ── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp
SMTP_PORT=587
SMTP_FROM=noreply@yourdomain.com
SMTP_HOSTNAME=mail.yourdomain.com
SMTP_ALLOWED_DOMAINS=yourdomain.com

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost

# ── Turnstile (Cloudflare) ───────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Sentry (optional) ────────────────────────────────────────
# Server/edge: SENTRY_DSN. Client: NEXT_PUBLIC_SENTRY_DSN (same value).
# Omit NEXT_PUBLIC_SENTRY_DSN for server-only error capture.
# Tunnel routes client events via /monitoring — no direct ingest.sentry.io.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# For source map uploads in CI (optional):
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=sntrys_xxx
