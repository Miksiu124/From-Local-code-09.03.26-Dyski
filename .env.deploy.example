# Kopiuj do .env.deploy (plik .env.deploy jest w .gitignore).
# Wymagane: VPS_HOST (IP lub hostname VPS).

VPS_HOST=your-vps.example.com
VPS_USER=root
VPS_PATH=/opt/contentvault

# Na produkcji Dyskiof, gdy dane live są w Docker volume "contentvault_postgres_cluster"
# (PG w docker-compose.use3566349.yml). Bez tego skrypt użyje zwykłego postgres_data (pusta baza, brak sesji).
# Ustaw tutaj: VPS_USE_POSTGRES_CLUSTER=1
# Dla git pull/CI: na serwerze skopiuj .env.vps.example → $VPS_PATH/.env.vps (ta sama flaga) — inaczej deploy z innej maszyny traci tę opcję.

GIT_BRANCH=main
