# Kopiuj do .env.deploy (plik .env.deploy jest w .gitignore).
# Wymagane: VPS_HOST (IP lub hostname VPS).

VPS_HOST=your-vps.example.com
VPS_USER=root
VPS_PATH=/opt/contentvault

# Na produkcji Dyskiof, gdy dane live są w Docker volume "contentvault_postgres_cluster"
# (PG w docker-compose.use3566349.yml). Bez tego skrypt podstawia tylko postgres_data.
# VPS_USE_POSTGRES_CLUSTER=1

GIT_BRANCH=main
