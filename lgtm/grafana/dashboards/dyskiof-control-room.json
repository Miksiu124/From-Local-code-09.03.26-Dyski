          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "id": 17,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=~\"$compose_service\",container_label_com_docker_compose_service!=\"\"}[5m]))",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ],
      "title": "CPU kontenerów (rdzenie) — w czasie",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 25, "lineWidth": 1, "stacking": { "mode": "none", "group": "A" } },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "id": 18,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull", "max"] } },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (container_memory_working_set_bytes{container_label_com_docker_compose_service=~\"$compose_service\",container_label_com_docker_compose_service!=\"\"})",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ],
      "title": "Pamięć robocza kontenerów (working set) — w czasie",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "id": 19,
      "panels": [],
      "title": "Bazy: Postgres i Redis (zasoby + „status” z metryk)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Bez dedykowanego eksportera: obserwuj skoki CPU/RAM (np. długie zapytania, backup).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 },
          "unit": "none"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 47 },
      "id": 20,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"postgres\"}[5m]))",
          "legendFormat": "postgres — CPU (rdzenie)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"redis\"}[5m]))",
          "legendFormat": "redis — CPU (rdzenie)",
          "refId": "B"
        }
      ],
      "title": "Postgres vs Redis — użycie CPU",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 22, "lineWidth": 1 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 47 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{container_label_com_docker_compose_service=\"postgres\"}",
          "legendFormat": "postgres",
          "refId": "A"
        },
        {
          "expr": "container_memory_working_set_bytes{container_label_com_docker_compose_service=\"redis\"}",
          "legendFormat": "redis",
          "refId": "B"
        }
      ],
      "title": "Postgres i Redis — pamięć robocza",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "`container_last_seen` to znacznik czasu ostatniej obserwacji. Różnica `time() - last_seen` powinna być mała (kilkadziesiąt sekund). Duże skoki mogą oznaczać problem z cAdvisorem lub zatrzymany kontener.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 1, "spanNulls": false },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 53 },
      "id": 22,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "max by (container_label_com_docker_compose_service) (time() - container_last_seen{container_label_com_docker_compose_service!=\"\"})",
          "legendFormat": "{{container_label_com_docker_compose_service}} — s od ostatniej obserwacji",
          "refId": "A"
        }
      ],
      "title": "Kontenery — opóźnienie ostatniej obserwacji cAdvisor (per serwis)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 },
      "id": 23,
      "panels": [],
