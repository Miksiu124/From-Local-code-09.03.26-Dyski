# Copy: cp .env.lgtm.example .env.lgtm && chmod 600 .env.lgtm
# Wymagane: docker-compose.lgtm.yml czyta plik .env.lgtm

# (GF_PATHS_DATA jest ustawione w docker-compose.lgtm.yml — nie duplikuj)
# Ustaw mocne haslo (inaczej niz domyslne "admin" z obrazu)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_to_long_secret

# Po wystawieniu Grazy przez nginx HTTPS: ustaw publiczny URL, np.:
#   GF_SERVER_ROOT_URL=https://grafana.example.com/
# Przed dodaniem vhostu mozesz tymczasowo: http://127.0.0.1:3001/
GF_SERVER_ROOT_URL=http://127.0.0.1:3001/

# Opcjonalnie: OTEL_LGTM_TAG=11.0.0  (pin tagu)
# OTEL_LGTM_MEMORY=3072M
# OTEL_LGTM_CPUS=1.0
# ENABLE_LOGS_ALL=1
